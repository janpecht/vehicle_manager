generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  role          Role     @default(USER)
  emailVerified Boolean  @default(false) @map("email_verified")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  refreshTokens     RefreshToken[]
  verificationCodes  EmailVerificationCode[]
  passwordResetCodes PasswordResetCode[]
  createdDamages     DamageMarking[] @relation("createdDamages")
  repairedDamages   DamageMarking[] @relation("repairedDamages")

  @@map("users")
}

model EmailVerificationCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_codes")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  tokenHash String   @unique @map("token_hash")
  userId    String   @map("user_id") @db.Uuid
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetCode {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  codeHash  String   @map("code_hash")
  expiresAt DateTime @map("expires_at")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_codes")
}

model VehicleType {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique
  frontImage String?  @map("front_image")
  rearImage  String?  @map("rear_image")
  leftImage  String?  @map("left_image")
  rightImage String?  @map("right_image")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  vehicles Vehicle[]
  images   VehicleTypeImage[]

  @@map("vehicle_types")
}

model VehicleTypeImage {
  id            String   @id @default(uuid()) @db.Uuid
  vehicleTypeId String   @map("vehicle_type_id") @db.Uuid
  side          String   @db.VarChar(10)
  data          Bytes
  mimeType      String   @map("mime_type") @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at")

  vehicleType VehicleType @relation(fields: [vehicleTypeId], references: [id], onDelete: Cascade)

  @@unique([vehicleTypeId, side])
  @@map("vehicle_type_images")
}

model Vehicle {
  id            String   @id @default(uuid()) @db.Uuid
  licensePlate  String   @unique @map("license_plate")
  label         String?
  vehicleTypeId String?  @map("vehicle_type_id") @db.Uuid
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  vehicleType    VehicleType?    @relation(fields: [vehicleTypeId], references: [id])
  damageMarkings DamageMarking[]
  checklistSubmissions ChecklistSubmission[]

  @@map("vehicles")
}

enum ViewSide {
  FRONT
  REAR
  LEFT
  RIGHT
}

enum Shape {
  CIRCLE
  RECTANGLE
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

model DamageMarking {
  id          String    @id @default(uuid()) @db.Uuid
  vehicleId   String    @map("vehicle_id") @db.Uuid
  viewSide    ViewSide  @map("view_side")
  shape       Shape
  x           Float
  y           Float
  width       Float
  height      Float
  description String?   @db.VarChar(500)
  severity    Severity
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   String    @map("created_by") @db.Uuid
  repairedAt  DateTime? @map("repaired_at")
  repairedBy  String?   @map("repaired_by") @db.Uuid
  isActive    Boolean   @default(true) @map("is_active")

  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  creator     User      @relation("createdDamages", fields: [createdBy], references: [id])
  repairer    User?     @relation("repairedDamages", fields: [repairedBy], references: [id])

  @@index([vehicleId])
  @@index([vehicleId, viewSide])
  @@index([vehicleId, isActive])
  @@map("damage_markings")
}

model Driver {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  checklistSubmissions ChecklistSubmission[]

  @@map("drivers")
}

enum DamageVisibility {
  NEW_DAMAGE
  KNOWN_DAMAGE
  NO_DAMAGE
}

enum FuelLevel {
  OK
  LOW
}

model ChecklistSubmission {
  id                String             @id @default(uuid()) @db.Uuid
  driverId          String             @map("driver_id") @db.Uuid
  vehicleId         String             @map("vehicle_id") @db.Uuid
  submittedAt       DateTime           @default(now()) @map("submitted_at")
  mileage           Int
  damageVisibility  DamageVisibility   @map("damage_visibility")
  dashboardWarnings String[]           @default([]) @map("dashboard_warnings")
  seatsDirty        Boolean            @default(false) @map("seats_dirty")
  smokedInVehicle   Boolean            @map("smoked_in_vehicle")
  foodLeftovers     Boolean            @map("food_leftovers")
  cargoAreaDirty    Boolean            @default(false) @map("cargo_area_dirty")
  freezerTempOk     Boolean            @map("freezer_temp_ok")
  chargingCablesOk  Boolean            @map("charging_cables_ok")
  deliveryNotesPresent Boolean?        @map("delivery_notes_present")
  fuelLevel         FuelLevel?         @map("fuel_level")
  carWashNeeded     Boolean?           @map("car_wash_needed")
  notes             String?            @db.VarChar(1000)
  createdAt         DateTime           @default(now()) @map("created_at")

  driver  Driver  @relation(fields: [driverId], references: [id])
  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  photos  ChecklistPhoto[]

  @@index([vehicleId])
  @@index([driverId])
  @@index([submittedAt])
  @@map("checklist_submissions")
}

model ChecklistPhoto {
  id           String   @id @default(uuid()) @db.Uuid
  submissionId String   @map("submission_id") @db.Uuid
  data         Bytes
  mimeType     String   @map("mime_type") @db.VarChar(50)
  filename     String   @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  submission ChecklistSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("checklist_photos")
}
